# =============================================================================
# Lokale dev: kopieer naar apps/backend/.env en apps/storefront/.env.local
# Dit bestand is een referentie van alle variabelen die de stack gebruikt.
# =============================================================================

# ----- Backend (apps/backend/.env) -----
NODE_ENV=development

# Secrets — genereer voor productie (`openssl rand -base64 32`)
JWT_SECRET=dev-jwt-supersecret-change-me
COOKIE_SECRET=dev-cookie-supersecret-change-me

STORE_CORS=http://localhost:8000
ADMIN_CORS=http://localhost:5173,http://localhost:9000
AUTH_CORS=http://localhost:5173,http://localhost:9000,http://localhost:8000

# Postgres (via docker compose, port 5433 zodat dit niet botst met Popify op 5432)
DATABASE_URL=postgres://medusa:medusa@localhost:5433/medusa

# Redis (via docker compose, port 6380)
REDIS_URL=redis://localhost:6380

# MinIO (S3-compatible, via docker compose, ports 9200/9201)
S3_FILE_URL=http://localhost:9200/medusa-files
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_REGION=eu-west-1
S3_BUCKET=medusa-files
S3_ENDPOINT=http://localhost:9200

# Mollie payments (vul in vanuit Mollie dashboard, https://my.mollie.com)
MOLLIE_API_KEY=test_xxxxxxxxxxxxxxxxxx

# SMTP (transactional email)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=username
SMTP_PASS=password
SMTP_FROM="SmartPowerDeals <noreply@example.com>"

# Storefront revalidation (backend roept storefront aan na product/price wijzigingen)
STOREFRONT_URL=http://localhost:8000
REVALIDATE_SECRET=dev-revalidate-secret-change-me

# ----- Storefront (apps/storefront/.env.local) -----
NEXT_PUBLIC_MEDUSA_BACKEND_URL=http://localhost:9000
NEXT_PUBLIC_BASE_URL=http://localhost:8000
NEXT_PUBLIC_DEFAULT_REGION=nl
# Maak na backend-seed in admin: Settings → Publishable API Keys
NEXT_PUBLIC_MEDUSA_PUBLISHABLE_KEY=pk_xxxxxxxxxxxxxxxxxx
# Moet matchen met REVALIDATE_SECRET aan backend-kant
REVALIDATE_SECRET=dev-revalidate-secret-change-me
